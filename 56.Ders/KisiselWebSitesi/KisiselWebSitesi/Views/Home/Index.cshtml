     <img width="250" height="250" src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1974&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Alternate Text" />
    </div>

    <h3>Hoş Geldiniz @kullaniciAdi</h3>

    <a>@ViewBag.TelNo </a>


    <a asp-controller="Home" asp-action="AboutMe" >Detaylı bilgi için...</a>

</div>
